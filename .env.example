# Database — PostgreSQL connection string
# Codespaces mein: postgresql://postgres:postgres@localhost:5432/ecommerce_db
# Local mein:      postgresql://postgres:YOUR_PASSWORD@localhost:5432/ecommerce_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce_db

# Session secret — koi bhi random string
SESSION_SECRET=change-this-to-a-random-secret-string
