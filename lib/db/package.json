{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "sh -c 'set -a; . ../../.env 2>/dev/null; set +a; drizzle-kit push --config ./drizzle.config.ts'",
    "push-force": "sh -c 'set -a; . ../../.env 2>/dev/null; set +a; drizzle-kit push --force --config ./drizzle.config.ts'"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
